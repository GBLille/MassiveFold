{
  "massivefold": {
    "jobfile_headers_dir": "./headers",
    "output_dir": "./output",
    "logs_dir": "./log",
    "input_dir": "./input",
    "pkl_format": "light"
  },
  "custom_params": {
  },
  "runs": {
    "af3_woPaired": {
      "args": {"predictions_per_model": 2, "batch_size": 1},
      "AF3_run": {
        "fasta_chains": [ "protein", "protein"],
        "pairedMsa": "false"
      }
    },
    "af3_woUnpaired": {
      "args": {"predictions_per_model": 2, "batch_size": 1},
      "AF3_run": {
        "fasta_chains": ["protein", "protein"],
        "unpairedMsa": "false"
      }
    },
    "afm_dropout_woTemplates": {
      "args": {"predictions_per_model": 1},
      "AFM_run": {
        "dropout": "true",
        "templates": "false"
      }
    }
  },
  "plots": {
    "MF_plots_top_n_predictions": "10",
    "MF_plots_chosen_plots": "DM_plddt_PAE,CF_PAEs"
  }
}
